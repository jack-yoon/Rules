(?<=&mcc_mnc=)46 url 307 44
(^https?:\/\/[\w-]+\.tiktokv.com\/.+&.+\d{2})(\.4)(\.\d.+) url 302 $1$3

# > Tiktok
^https://api[\w-]*?.tiktokv.com/aweme/v\d/policy/notice/? url reject
^https?:\/\/[\w-]+\.(amemv|musical|snssdk|tiktokv)\.(com|ly)\/(api|motor)\/ad\/ url reject
^https?:\/\/[\w-]+\.snssdk\.com\/.+_ad\/ url reject
